# ========== 服务 ==========
PORT=3001

# ========== 阿里云百炼 ==========
BAILIAN_API_KEY=sk-...
BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ========== 百度千帆 ==========
QIANFAN_API_KEY=bce-v3/ALTAK-.../...
QIANFAN_BASE_URL=https://qianfan.baidubce.com/v2

# ========== 火山方舟 ==========
VOLCANO_API_KEY=ark-...
VOLCANO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# 可选：ep- 接入点 ID，填入后覆盖 MODEL_ROUTING 中的火山模型名
VOLCANO_ENDPOINT_DOUBAO_SEED_2_0_PRO=
VOLCANO_ENDPOINT_DOUBAO_SEED_CHARACTER=

# ========== 模型路由 ==========
# 格式: 前端模型ID=provider:api模型名
# provider: bailian | qianfan | volcano
# 千帆 model 名须小写，如 ernie-x1-turbo-32k
MODEL_ROUTING=qwen3.7-max=bailian:qwen3.7-max,qwen3.6-flash=bailian:qwen3.6-flash,deepseek-v4-flash=bailian:deepseek-v4-flash,kimi-k2.6=bailian:kimi-k2.6,glm-5.1=bailian:glm-5.1,MiniMax-M2.5=bailian:MiniMax-M2.5,ernie-x1-turbo-32k=qianfan:ernie-x1-turbo-32k,ernie-4.5-turbo-128k=qianfan:ernie-4.5-turbo-128k,Doubao-Seed-2.0-pro=volcano:doubao-seed-2-0-pro-260215,Doubao-Seed-Character=volcano:doubao-seed-character-251128

# ========== 用户画像 Agent ==========
PROFILE_AGENT_PROVIDER=bailian
PROFILE_AGENT_MODEL=qwen3.6-flash
